{
  "name": "medusa-payment-mpesa",
  "version": "1.0.0",
  "description": "Medusa v2 M-Pesa (Safaricom Daraja) payment provider — STK Push, polling, and refunds",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/medusa-payment-mpesa.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/medusa-payment-mpesa/issues"
  },
  "homepage": "https://github.com/your-org/medusa-payment-mpesa#readme",
  "keywords": [
    "medusa-plugin-integration",
    "medusa-v2",
    "medusa-plugin-payment",
    "mpesa",
    "safaricom",
    "daraja",
    "kenya",
    "africa",
    "lipa-na-mpesa",
    "stk-push"
  ],
  "files": [
    ".medusa/server",
    "src",
    "!src/**/__tests__",
    "!**/*.test.ts"
  ],
  "main": "./.medusa/server/src/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "develop": "medusa plugin:develop",
    "publish:local": "medusa plugin:publish",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@medusajs/admin-shared": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/test-utils": "2.15.2",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.12.11",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.3.0",
    "@medusajs/medusa": ">=2.3.0"
  },
  "peerDependenciesMeta": {
    "@medusajs/framework": {
      "optional": false
    },
    "@medusajs/medusa": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=20"
  }
}
